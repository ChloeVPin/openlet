{
  "name": "openlet",
  "version": "0.1.0",
  "private": false,
  "description": "Free, open-source flashcard app with spaced repetition. Quizlet product feel without the paywall.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChloeVPin/openlet"
  },
  "keywords": [
    "flashcards",
    "study",
    "spaced-repetition",
    "fsrs",
    "quizlet",
    "education",
    "open-source",
    "tanstack",
    "react"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node dist/server/server.js",
    "start:dev": "vite build && vite dev --port 3000",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "logos": "node scripts/generate-logo-assets.mjs",
    "seed:test-user": "node --env-file=.env scripts/seed-test-user.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:stack": "pnpm seed:test-user && vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-query": "^5.101.3",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.168.32",
    "@tanstack/router-plugin": "^1.168.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.25.0",
    "postgres": "^3.4.9",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "workbox-window": "^7.4.1"
  }
}
